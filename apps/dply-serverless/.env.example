APP_NAME="dply Serverless"
APP_ENV=local
# Required for encrypted project credentials (serverless_projects.credentials).
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Main dply app (BYO) — Fortify login/register/dashboard. Used for marketing header/footer links.
# DPLY_MAIN_APP_URL=https://dply.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Laravel Pennant: database (default) persists overrides; array is fine for tests / ephemeral.
# PENNANT_STORE=database

# Feature flags (ADR-006). Spike route defaults on in local/testing only unless overridden.
# SERVERLESS_INTERNAL_SPIKE=false
# Public /serverless overview (non-secret); default on if unset.
# SERVERLESS_PUBLIC_DASHBOARD=false

# Provisioner: local | aws | digitalocean | cloudflare | netlify | vercel | azure | gcp
# cloudflare / netlify / vercel: stub unless *_USE_REAL_API + path prefix (see comments below).
SERVERLESS_PROVISIONER=local
SERVERLESS_AWS_USE_REAL_SDK=false
# Optional: UpdateFunctionCode with a local zip (requires prefix; path must stay under it).
SERVERLESS_AWS_UPLOAD_ZIP=false
# e.g. /var/app/zips — empty = never upload from disk (GetFunction / describe-only unless zip branch runs).
SERVERLESS_AWS_ZIP_PATH_PREFIX=
# Max zip size in bytes (default ~45MB; Lambda direct upload limit is 50MB).
# SERVERLESS_AWS_ZIP_MAX_BYTES=47185920

# Comma-separated bucket names allowed for artifact_path s3://bucket/key.zip (optional ?versionId=).
# Empty = s3:// artifacts are rejected. Lambda reads the object from your account (IAM must allow s3:GetObject).
# SERVERLESS_AWS_S3_ALLOW_BUCKETS=my-build-artifacts

# Cloudflare Workers (real API when provisioner=cloudflare)
# SERVERLESS_CLOUDFLARE_USE_REAL_API=false
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_WORKERS_COMPATIBILITY_DATE=2024-11-01
# Local script files must sit under this directory (same idea as AWS zip prefix)
# CLOUDFLARE_WORKER_SCRIPT_PATH_PREFIX=
# CLOUDFLARE_WORKER_SCRIPT_MAX_BYTES=3145728

# DigitalOcean Functions (OpenWhisk REST zip when provisioner=digitalocean)
# SERVERLESS_DIGITALOCEAN_USE_REAL_API=false
# API host from doctl serverless status / connect (no trailing slash), namespace id, access key dof_v1_…:secret
# DIGITALOCEAN_FUNCTIONS_API_HOST=
# DIGITALOCEAN_FUNCTIONS_NAMESPACE=
# DIGITALOCEAN_FUNCTIONS_ACCESS_KEY=
# DIGITALOCEAN_FUNCTIONS_ZIP_PATH_PREFIX=
# Per-project (settings): digitalocean_functions_zip_path_prefix — under global prefix, same as Netlify/Vercel.
# DIGITALOCEAN_FUNCTIONS_ZIP_MAX_BYTES=47185920
# DIGITALOCEAN_FUNCTIONS_ACTION_KIND=nodejs:18
# DIGITALOCEAN_FUNCTIONS_ACTION_MAIN=index.js
# Optional non-default package segment in the action path:
# DIGITALOCEAN_FUNCTIONS_PACKAGE=

# Netlify (real zip deploy when provisioner=netlify)
# SERVERLESS_NETLIFY_USE_REAL_API=false
# NETLIFY_AUTH_TOKEN=     # personal access token (sites:write or deploy scope)
# NETLIFY_SITE_ID=        # API site UUID
# Local zips must live under this directory (same safety model as AWS zip prefix)
# NETLIFY_DEPLOY_ZIP_PATH_PREFIX=
# Per-project (settings): netlify_deploy_zip_path_prefix — must be this path or a subdirectory (exists on disk).
# NETLIFY_DEPLOY_ZIP_MAX_BYTES=47185920

# Vercel (zip → POST /v13/deployments when provisioner=vercel)
# SERVERLESS_VERCEL_USE_REAL_API=false
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=          # optional; adds ?teamId= for team/scope
# VERCEL_PROJECT_ID=       # prj_… (preferred) — overrides project name when set
# VERCEL_PROJECT_NAME=     # used when PROJECT_ID empty
# VERCEL_DEPLOY_ZIP_PATH_PREFIX=
# Per-project (settings): vercel_deploy_zip_path_prefix — must be this path or a subdirectory (exists on disk).
# VERCEL_DEPLOY_ZIP_MAX_BYTES=47185920
# VERCEL_DEPLOY_MAX_ZIP_ENTRIES=2000
# VERCEL_DEPLOY_MAX_UNCOMPRESSED_BYTES=52428800

# Webhook: POST /api/webhooks/serverless/deploy (HMAC X-Dply-Signature, optional X-Dply-Timestamp)
SERVERLESS_WEBHOOK_SECRET=
# Optional comma-separated allow list (IPv4 or CIDR); leave empty to allow any IP.
SERVERLESS_WEBHOOK_ALLOWED_IPS=

# API: POST /api/serverless/deploy — Authorization: Bearer <token>
SERVERLESS_API_TOKEN=

# JSON body may omit these; defaults apply.
SERVERLESS_DEFAULT_FUNCTION_NAME=app
SERVERLESS_DEFAULT_RUNTIME=provided.al2023
SERVERLESS_DEFAULT_ARTIFACT_PATH=/dev/null

# Use a database dedicated to this app — never the BYO `dply` / `dply_byo` database.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dply_serverless
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Local: database or sync. Lambda (serverless.yml): sqs + SQS_QUEUE from CloudFormation — see docs/BREF_LAMBDA_QUEUE.md
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

{
  "openapi": "3.0.3",
  "info": {
    "title": "dply Server Firewall API",
    "version": "1.0.0",
    "description": "HTTP API v1 firewall endpoints under /api/v1. Requires auth.api with network.read / network.write abilities as noted. The basics-first API supports listing a server's rules and templates, applying the current enabled rules, and adding bundled or saved templates. ETag on GET /servers/{server}/firewall is the SHA-256 of the ordered rule set (use If-None-Match for 304)."
  },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/servers/{server}/firewall": {
      "get": {
        "summary": "List firewall rules and templates",
        "operationId": "firewallShow",
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "ETag from prior response"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "ETag": { "schema": { "type": "string" } }
            }
          },
          "304": { "description": "Not modified" }
        }
      }
    },
    "/servers/{server}/firewall/apply": {
      "post": {
        "summary": "Apply enabled rules via UFW",
        "operationId": "firewallApply",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "acknowledge_ssh_lockout_risk": {
                    "type": "boolean",
                    "description": "Required when no enabled rule allows SSH from any."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Applied" },
          "422": { "description": "SSH ack required (code ssh_lockout_ack_required)" },
          "500": { "description": "Apply failed on host" }
        }
      }
    },
    "/servers/{server}/firewall/bundled/{key}": {
      "post": {
        "summary": "Apply a bundled firewall template",
        "operationId": "firewallBundledApply"
      }
    },
    "/servers/{server}/firewall/templates/{template}": {
      "post": {
        "summary": "Apply a saved firewall template",
        "operationId": "firewallTemplateApply"
      }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "dply Server Firewall API",
    "version": "1.0.0",
    "description": "HTTP API v1 firewall endpoints under /api/v1. Requires auth.api with network.read / network.write abilities as noted. ETag on GET /servers/{server}/firewall is the SHA-256 of the ordered rule set (use If-None-Match for 304). Dual-approver workflow applies to the web UI only, not API applies. Organization-level firewall options (drift webhooks, synthetic probe URL, second approval) are stored in organizations.firewall_settings JSON and merged with config server_firewall.organization_settings for app behavior; those flags are not exposed on this REST surface."
  },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/servers/{server}/firewall": {
      "get": {
        "summary": "List firewall rules and templates",
        "operationId": "firewallShow",
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "ETag from prior response"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "ETag": { "schema": { "type": "string" } }
            }
          },
          "304": { "description": "Not modified" }
        }
      }
    },
    "/servers/{server}/firewall/preview": {
      "get": {
        "summary": "Preview UFW shell commands for enabled rules",
        "operationId": "firewallPreview"
      }
    },
    "/servers/{server}/firewall/drift": {
      "get": {
        "summary": "Compare Dply rules to ufw status verbose",
        "operationId": "firewallDrift"
      }
    },
    "/servers/{server}/firewall/terraform": {
      "get": {
        "summary": "Terraform-style HCL snippet (documentation)",
        "operationId": "firewallTerraform"
      }
    },
    "/servers/{server}/firewall/iptables": {
      "get": {
        "summary": "iptables -L -n -v snapshot (first rows)",
        "description": "403 when SERVER_FIREWALL_IPTABLES_COUNTERS is not enabled.",
        "operationId": "firewallIptables"
      }
    },
    "/servers/{server}/firewall/apply": {
      "post": {
        "summary": "Apply enabled rules via UFW",
        "operationId": "firewallApply",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "acknowledge_ssh_lockout_risk": {
                    "type": "boolean",
                    "description": "Required when no enabled rule allows SSH from any."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Applied" },
          "422": { "description": "SSH ack required (code ssh_lockout_ack_required)" },
          "423": { "description": "Maintenance window (code maintenance)" },
          "500": { "description": "Apply failed on host" }
        }
      }
    },
    "/servers/{server}/firewall/export": {
      "get": {
        "summary": "Download JSON export (version 2)",
        "operationId": "firewallExport"
      }
    },
    "/servers/{server}/firewall/import": {
      "post": {
        "summary": "Import JSON (replace or merge per body)",
        "operationId": "firewallImport"
      }
    }
  }
}

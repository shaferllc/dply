###############################################################################
# dply — PRODUCTION WORKER (.env) example. Real structure, secrets redacted.
# Role=worker: runs Horizon (provisioning/deploys/edge/billing). Carries every
# SHARED secret + the worker overlay (ClickHouse, log-drain TLS, server-logs).
# APP_KEY MUST match the web box. Copy to worker shared/.env, fill the secrets.
###############################################################################
APP_DEBUG=true
APP_ENV=production
APP_KEY=__set_from_secret_store__
APP_NAME=dply
APP_URL=https://dply.io
AWS_ACCESS_KEY_ID=
AWS_BUCKET=
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=
BROADCAST_CONNECTION=pusher
CACHE_STORE=database
DATABASE_URL=postgresql://dply_3xz5:XnP8PuxrtdHwU8YD7nrZeDFvymCSFYw6@10.0.0.3:5432/dply
DB_CONNECTION=pgsql
DB_DATABASE=dply
DB_HOST=10.0.0.3
DB_PASSWORD=__set_from_secret_store__
DB_PORT=5432
DB_USERNAME=dply_3xz5
DPLY_RUNTIME=worker
DPLY_WORKER_ROLE=primary
# FEATURE_WORKSPACE_BACKUPS=true
# FEATURE_WORKSPACE_BACKUPS_PREVIEW=true
# FEATURE_WORKSPACE_SSH_ACCESS_GRAPH=true
# FEATURE_WORKSPACE_SSH_ACCESS_GRAPH_PREVIEW=true
# FEATURE_WORKSPACE_PATCH_ADVISOR=true
# FEATURE_WORKSPACE_RELEASE_HYGIENE=true
# FEATURE_WORKSPACE_RELEASE_HYGIENE_PREVIEW=true
# FEATURE_WORKSPACE_DAEMON_SLO=true
# FEATURE_WORKSPACE_CERT_INVENTORY=true
# FEATURE_WORKSPACE_DEPLOY_WINDOWS=true
# FEATURE_WORKSPACE_DEPLOY_WINDOWS_PREVIEW=true
# FEATURE_WORKSPACE_SSH_ACCESS_GRAPH=true
# FEATURE_WORKSPACE_SSH_SESSIONS=true
# FEATURE_WORKSPACE_CONSOLE=true
# FEATURE_WORKSPACE_CONSOLE_PREVIEW=false
# FEATURE_WORKSPACE_RUN=false
# FEATURE_WORKSPACE_RUN_PREVIEW=true
# FEATURE_WORKSPACE_SERVER_COST=true
# FEATURE_WORKSPACE_SECURITY_DIGEST=true
# FEATURE_WORKSPACE_SECURITY_DIGEST_PREVIEW=true
# Tier B workflows (see docs/TIER_B_WORKFLOW.md)
# FEATURE_LAUNCH_FULL_STACK_WIZARD=true
# FEATURE_GLOBAL_BYO_REPO_CONFIG=true
# FEATURE_GLOBAL_EDGE_DEPLOY_REPLAY=true
# Product surface flags (Cloud, Edge, Serverless). Off = Soon badge in nav + no routes.
# Product surface feature flags (Pennant; see config/features.php). Set false to hide a surface.
# VM workspace (see docs/DIFFERENTIATION_IDEAS.md)
# FEATURE_WORKSPACE_SERVER_BLUEPRINT=true
# FEATURE_WORKSPACE_WEBSERVER_CONFIG_DIFF=true
# FEATURE_WORKSPACE_SERVER_MAINTENANCE=true
# FEATURE_WORKSPACE_SERVER_MAINTENANCE_PREVIEW=true
FILESYSTEM_DISK=local
HORIZON_NAME=dply-worker-1
LOG_CHANNEL=stack
LOG_LEVEL=debug
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=${APP_NAME}
MAIL_HOST=127.0.0.1
MAIL_MAILER=log
MAIL_PASSWORD=__set_from_secret_store__
MAIL_PORT=2525
MAIL_SCHEME=null
MAIL_USERNAME=null
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=10.0.0.2
REDIS_PASSWORD=__set_from_secret_store__
REDIS_PORT=6379
# Port Reverb binds to (`php artisan reverb:start`). 8080 is often busy.
SESSION_DOMAIN=null
SESSION_DRIVER=database
REDIS_QUEUE=dply
PUSHER_APP_ID=__set_from_secret_store__
PUSHER_APP_KEY=__set_from_secret_store__
PUSHER_APP_SECRET=__set_from_secret_store__
PUSHER_HOST=dply-realtime.flat-thunder-531a.workers.dev
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# --- dply Logs (added by setup) ---
SERVER_LOGS_AGGREGATOR_ENDPOINT=134.209.13.103:6000
SERVER_LOGS_CA_CERT_B64=__set_from_secret_store__
SERVER_LOGS_CLIENT_CERT_B64=__set_from_secret_store__
SERVER_LOGS_CLIENT_KEY_B64=__set_from_secret_store__
CLICKHOUSE_HOST=134.209.13.103
CLICKHOUSE_SCHEME=https
CLICKHOUSE_DATABASE=dply_logs
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=__set_from_secret_store__
CLICKHOUSE_CA_CERT_B64=__set_from_secret_store__
# --- end dply Logs ---

# dply Logs app-log drain (private network)
DPLY_LOG_DRAIN_HOST=logs-drain.dply.io
DPLY_LOG_DRAIN_PORT=9514
DPLY_LOG_DRAIN_TLS=true
DPLY_LOG_DRAIN_TLS_CERT=__set_from_secret_store__
DPLY_LOG_DRAIN_TLS_KEY=__set_from_secret_store__

# Testing-hostname provisioning (mirrored from app server)
DIGITALOCEAN_TOKEN=__set_from_secret_store__
DPLY_EDGE_TESTING_DOMAINS=on-dply.site
DPLY_TESTING_DOMAINS=dply.app,dply.cc,dply.forum,dply.host,dply.ink,dply.llc,dply.us,dply.online,dply.site,dply.space
DPLY_TESTING_DOMAINS_CLOUDFLARE=on-dply.live,on-dply.online
DPLY_TESTING_DOMAINS_DIGITALOCEAN=on-dply.app,on-dply.cloud,on-dply.site
DPLY_TESTING_DOMAINS_HETZNER=on-dply.cc,on-dply.com


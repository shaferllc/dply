{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/shaferllc/dply-php-lambda.git"
        },
        {
            "type": "path",
            "url": "packages/log-parser",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/nginx-config",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "aws/aws-sdk-php": "^3.373",
        "bacon/bacon-qr-code": "^3.0",
        "blade-ui-kit/blade-heroicons": "^2.7",
        "blade-ui-kit/blade-icons": "^1.9",
        "dply/log-parser": "@dev",
        "dply/nginx-config": "@dev",
        "laravel/cashier": "^16.5",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/mcp": "^0.8.0",
        "laravel/passkeys": "^0.1.0",
        "laravel/pennant": "^1.23",
        "laravel/pulse": "^1.7",
        "laravel/reverb": "^1.9",
        "laravel/socialite": "^5.25",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.34",
        "livewire/blaze": "^1.0",
        "livewire/livewire": "^4.0",
        "lorisleiva/cron-translator": "^0.5.1",
        "phpseclib/phpseclib": "^3.0",
        "pragmarx/google2fa": "^9.0",
        "sebastian/diff": "^7.0",
        "shaferllc/dply-php-lambda": "@dev",
        "spatie/temporary-directory": "^2.3",
        "symfony/http-client": "^8.1",
        "symfony/yaml": "^8.0",
        "yosymfony/toml": "^1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "beyondcode/expose": "^3.2",
        "brianium/paratest": "^7.0",
        "deptrac/deptrac": "^3.0",
        "doctrine/dbal": "^4.0",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-drift": "^4.1",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^12.5.12",
        "soloterm/solo": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev:all": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#34d399\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan reverb:start\" --names=server,queue,logs,vite,reverb --kill-others"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#34d399\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"php artisan reverb:start\" --names=queue,logs,reverb --kill-others"
        ],
        "dev:horizon:all": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#34d399\" \"php artisan serve\" \"php artisan horizon:listen\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan reverb:start\" --names=server,horizon,vite,logs,reverb --kill-others"
        ],
        "dev:horizon": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#34d399\" \"php artisan serve\" \"php artisan horizon:listen\" \"php artisan pail --timeout=0\" \"php artisan reverb:start\" --names=horizon,logs,reverb --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "analyse": [
            "@php -d memory_limit=1G vendor/bin/phpstan analyse --no-progress"
        ],
        "analyse:baseline": [
            "@php -d memory_limit=1G vendor/bin/phpstan analyse --no-progress --generate-baseline=phpstan-baseline.neon"
        ],
        "deptrac": [
            "@php vendor/bin/deptrac analyse --no-progress"
        ],
        "deptrac:baseline": [
            "@php vendor/bin/deptrac analyse --formatter=baseline --output=deptrac-baseline.yaml --no-progress"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

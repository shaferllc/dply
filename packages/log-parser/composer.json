{
    "name": "dply/log-parser",
    "description": "Tolerant, dependency-free parsers that turn raw Laravel/Monolog and NGINX/Apache error-log text into structured records.",
    "license": "MIT",
    "type": "library",
    "keywords": ["log", "parser", "monolog", "laravel", "nginx", "apache", "dply"],
    "require": {
        "php": ">=8.3",
        "ext-json": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Dply\\LogParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dply\\LogParser\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}

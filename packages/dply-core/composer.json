{
    "name": "shaferllc/dply-core",
    "description": "Shared primitives for dply product apps (BYO, Serverless, Cloud, …)",
    "type": "library",
    "license": "MIT",
    "version": "0.1.1",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Dply\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dply\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

{
    "name": "dply/nginx-config",
    "description": "Parse, build and diff NGINX configuration as a structured directive tree. A modernized fork of nelexa/crossplane (a PHP port of nginx's crossplane), trimmed to the parser core.",
    "license": "Apache-2.0",
    "type": "library",
    "keywords": ["nginx", "config", "parser", "crossplane", "dply"],
    "require": {
        "php": ">=8.3",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Dply\\NginxConfig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dply\\NginxConfig\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}

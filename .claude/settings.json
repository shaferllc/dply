      "Bash(git clean:-f*)",
      "Bash(git clean:-d*)",
      "Bash(git checkout:--force*)",
      "Bash(git worktree:remove --force*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(brew:*)"
    ]
  }
}
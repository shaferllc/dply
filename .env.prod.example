###############################################################################
# dply — PRODUCTION WEB (.env) example. Real structure, secrets redacted.
# Copy to the web box shared/.env, fill __set_from_secret_store__ values.
# APP_KEY MUST be byte-identical on web + every worker. Constants/tuning now
# live in config/*.php (see docs/ENV_AUDIT.md), so they are intentionally absent.
###############################################################################
APP_DEBUG=false
APP_ENV=production
APP_KEY=__set_from_secret_store__
APP_NAME=dply
APP_URL=https://dply.io
AWS_ACCESS_KEY_ID=
AWS_BUCKET=
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=
BITBUCKET_CLIENT_ID=__set_from_secret_store__
BITBUCKET_CLIENT_SECRET=__set_from_secret_store__
CACHE_STORE=database
DATABASE_URL=postgresql://dply_3xz5:XnP8PuxrtdHwU8YD7nrZeDFvymCSFYw6@10.0.0.3:5432/dply
DB_CONNECTION=pgsql
DB_DATABASE=dply
DB_HOST=10.0.0.3
DB_PASSWORD=__set_from_secret_store__
DB_PORT=5432
DB_SCHEMA_BINARY_PATH=
DB_USERNAME=dply_3xz5
# DigitalOcean OAuth for Server providers (optional; separate from Git OAuth). Callback: {APP_URL}/credentials/oauth/digitalocean/callback
DIGITALOCEAN_OAUTH_CLIENT_ID=__set_from_secret_store__
DIGITALOCEAN_OAUTH_CLIENT_SECRET=__set_from_secret_store__
DIGITALOCEAN_OAUTH_REDIRECT_URI=${DPLY_PUBLIC_APP_URL}/credentials/oauth/digitalocean/callback
# Optional personal access token: load DigitalOcean regions & droplet prices on the create-server wizard
# when no org credential is selected (provisioning still uses the selected Server providers credential).
# REQUIRED for ServerlessFunctionDnsProvisioner to write {slug}.dply.host CNAMEs — paste your DO PAT.
DIGITALOCEAN_TOKEN=__set_from_secret_store__
# Auto-create temporary testing hostnames on your owned DigitalOcean DNS zones.
# Remove the on-box repo/release tree when a site is deleted, so a re-created
# same-slug site starts fresh (splash page, no inherited code). Cleanup runs sudo.
# Edge build container image — leave unset to let NodeVersionDetector pick from
# the repo's engines.node / .nvmrc / .node-version. Set explicitly to force one
# image for every build (e.g. node:20-bookworm if you need a hard pin).
# DPLY_EDGE_BUILD_IMAGE=node:22-bookworm
DPLY_EDGE_CF_ACCOUNT_ID=7b04f7af0455bad4f97632f4f490f5de
DPLY_EDGE_CF_ANALYTICS_DATASET=dply_edge_requests
DPLY_EDGE_CF_API_TOKEN=__set_from_secret_store__
DPLY_EDGE_CF_CACHE_KV_NAMESPACE_ID=0b932e0ded4d4e748116aee8a6bc9814
DPLY_EDGE_CF_KV_NAMESPACE_ID=10cfe302069a4c52b3c412a5e8e775d8
DPLY_EDGE_CF_WORKER_ROUTES=*.on-dply.site/*
DPLY_EDGE_CF_WORKER_SCRIPT=dply-edge
DPLY_EDGE_CF_ZONE_NAME=on-dply.site
DPLY_EDGE_LOGPUSH_DESTINATION_URL=https://dplyi.test/hooks/edge/logpush
DPLY_EDGE_LOGPUSH_SECRET=__set_from_secret_store__
DPLY_EDGE_LOG_INGEST_BASE_URL=https://dplyi.test
DPLY_EDGE_LOG_INGEST_KEY=__set_from_secret_store__
DPLY_EDGE_R2_ACCESS_KEY=__set_from_secret_store__
# dply Edge — first-party static/SSG delivery (R2 + Cloudflare Worker)
DPLY_EDGE_R2_BUCKET=dply-edge-artifacts
DPLY_EDGE_R2_ENDPOINT=https://7b04f7af0455bad4f97632f4f490f5de.r2.cloudflarestorage.com
# DPLY_EDGE_R2_PATH_STYLE=true
DPLY_EDGE_R2_KEY_PREFIX=edge/
DPLY_EDGE_R2_REGION=auto
DPLY_EDGE_R2_SECRET=__set_from_secret_store__
DPLY_EDGE_TESTING_DOMAINS=on-dply.site
# Local dply Logs (app-log drain) receiver
DPLY_LOG_DRAIN_HOST=127.0.0.1
DPLY_LOG_DRAIN_PORT=9514
DPLY_LOG_DRAIN_TLS=false
DPLY_POOL_EVENT_TOKEN=__set_from_secret_store__
DPLY_POOL_EVENT_URL=${APP_URL}/api/worker-pools/01kt6xt5rfnp7hrjc4xsn3t02f/job-events
DPLY_TESTING_DOMAINS=dply.app,dply.cc,dply.forum,dply.host,dply.ink,dply.llc,dply.us,dply.online,dply.site,dply.space
DPLY_TESTING_DOMAINS_CLOUDFLARE=on-dply.live,on-dply.online
DPLY_TESTING_DOMAINS_DIGITALOCEAN=on-dply.app,on-dply.cloud,on-dply.site
DPLY_TESTING_DOMAINS_HETZNER=on-dply.cc,on-dply.com
DPLY_WORKER_ROLE=primary
FILESYSTEM_DISK=local
# OAuth / Git providers (optional; leave empty to hide "Continue with GitHub" etc.)
GITHUB_CLIENT_ID=__set_from_secret_store__
GITHUB_CLIENT_SECRET=__set_from_secret_store__
GITHUB_OAUTH_REDIRECT_URI=${DPLY_PUBLIC_APP_URL}/credentials/oauth/github/callback
GITLAB_CLIENT_ID=__set_from_secret_store__
GITLAB_CLIENT_SECRET=__set_from_secret_store__
HETZNER_TOKEN=__set_from_secret_store__
HORIZON_BALANCE=auto
HORIZON_JOB_TIMEOUT=720
HORIZON_MAX_PROCESSES=8
HORIZON_MIN_PROCESSES=1
HORIZON_NAME=dply-worker-1
HORIZON_QUEUES=default,dply,dply-control,probes:worker-1
HORIZON_TRIES=1
HORIZON_WORKER_MEMORY=128
LINODE_TOKEN=__set_from_secret_store__
LOG_CHANNEL=stack
LOG_LEVEL=debug
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=${APP_NAME}
MAIL_HOST=127.0.0.1
MAIL_MAILER=log
MAIL_PASSWORD=__set_from_secret_store__
MAIL_PORT=2525
MAIL_SCHEME=null
MAIL_USERNAME=null
NAMECHEAP_API_KEY=__set_from_secret_store__
# Namecheap
NAMECHEAP_API_USER=tshafer
NAMECHEAP_CLIENT_IP=66.10.105.85
OVH_API_CONSUMER_KEY=__set_from_secret_store__
OVH_API_KEY=__set_from_secret_store__
OVH_API_SECRET=__set_from_secret_store__
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=10.0.0.2
REDIS_PASSWORD=__set_from_secret_store__
REDIS_PORT=6379
REDIS_QUEUE=default
SESSION_DOMAIN=null
SESSION_DRIVER=database
STRIPE_KEY=__set_from_secret_store__
STRIPE_SECRET=__set_from_secret_store__
STRIPE_WEBHOOK_SECRET=
VULTR_TOKEN=__set_from_secret_store__

# Broadcasting: CF relay (mirrored from worker) — replaces retired Reverb
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=__set_from_secret_store__
PUSHER_APP_KEY=__set_from_secret_store__
PUSHER_APP_SECRET=__set_from_secret_store__
PUSHER_HOST=dply-realtime.flat-thunder-531a.workers.dev
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

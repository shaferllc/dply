APP_NAME=dply
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# ASSET_URL="${APP_URL}"

# Optional: public URL cloud VMs / workers use for TaskRunner signed webhooks (stack provision).
# When APP_URL is not reachable from the server (e.g. http://127.0.0.1), set this to your tunnel
# or ingress HTTPS origin. Leave unset to use APP_URL for signed routes.
# DPLY_PUBLIC_APP_URL=https://dplyi.tunnel.dply.io

# Central identity federation (apps/dply-auth + Passport). Register {APP_URL}/oauth/callback on the BYO OAuth client.
# DPLY_AUTH_ENABLED=false
# DPLY_AUTH_URL=http://dply-auth.test
# DPLY_AUTH_CLIENT_ID=
# DPLY_AUTH_CLIENT_SECRET=
# DPLY_AUTH_REDIRECT_URI="${APP_URL}/oauth/callback"

# When tunnelling the app (e.g. Beyond Code Expose at https://expose.dev), set APP_URL (and
# ASSET_URL if you use a CDN) to the public https URL so OAuth redirects and signed URLs match.
# DigitalOcean droplet provisioning uses the API + polling jobs — no inbound “server ready”
# callback. Site deploy webhooks are separate; Expose is mainly for control-plane OAuth/Git.
# TRUSTED_PROXIES=*

# Solo → Expose pane: local URL to tunnel (see beyondcode/expose in composer.json require-dev).
# SOLO_EXPOSE_SHARE_URL=https://dplyi.test
# If `expose` is installed globally on PATH: SOLO_EXPOSE_COMMAND=expose

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dply
DB_USERNAME=postgres
DB_PASSWORD=

# DB_URL=postgresql://postgres@127.0.0.1:5432/dply?schema=public

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use `reverb` when running `php artisan reverb:start` (see composer script `composer dev`).
BROADCAST_CONNECTION=reverb

# Laravel Reverb (WebSockets). `php artisan reverb:install` generates app id/key/secret.
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# --- Local Reverb ---
REVERB_HOST=localhost
# Port Reverb binds to (`php artisan reverb:start`). 8080 is often busy.
REVERB_SERVER_PORT=8081
# Optional override for the browser port. If unset: http uses REVERB_SERVER_PORT; https in APP_ENV=local
# also uses REVERB_SERVER_PORT (TLS on Reverb via Valet/Herd certs — no nginx). Production https defaults to 443.
# REVERB_PORT=8081
# http = ws://. https = wss:// — with REVERB_HOST matching your *.test site, Reverb loads Valet/Herd TLS certs.
REVERB_SCHEME=http

# Must match REVERB_* for the client. Rebuild after changes: npm run dev / npm run build.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
# false = do not load Laravel Echo (no WebSocket client). Useful when Reverb is not running.
# VITE_REVERB_ENABLED=true
# true = skip the localhost+wss and mixed-content guards (e.g. TLS-terminated Reverb on localhost).
# VITE_REVERB_BYPASS_LOCAL_GUARD=false
#
# HTTPS site (e.g. https://dplyi.test) without editing nginx: set REVERB_HOST to that hostname (same as
# Valet/Herd site), REVERB_SCHEME=https, keep REVERB_SERVER_PORT and omit REVERB_PORT (client port matches
# server). Reverb enables TLS when it finds matching certs under ~/.config/valet or Herd. Run reverb:start.
# Alternative: load the app over http:// with REVERB_SCHEME=http, or terminate TLS on 443 with a reverse
# proxy (see https://laravel.com/docs/reverb#running-reverb-behind-a-reverse-proxy).
# Optional nginx example: nginx/reverb-behind-valet.example.conf
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Laravel Horizon only consumes Redis queues. For queued work (cron “Run now”, manage SSH, etc.) to show
# in Horizon and run at all, use: QUEUE_CONNECTION=redis (requires Redis + phpredis). With database
# queues, use `php artisan queue:work` instead — Horizon will stay empty for those jobs.
# Run `composer dev:horizon` or the Horizon pane in Solo. Both use `php artisan horizon:listen`,
# which watches the paths in config/horizon.php and restarts Horizon when local files change.
# Dashboard: /horizon (any signed-in user when APP_ENV=local).
# HORIZON_ALLOWED_EMAILS=you@company.com,ops@company.com
# HORIZON_LOCAL_JOB_TIMEOUT=120
# Parallel queue workers when APP_ENV=local (Horizon). Default 8; raise for more concurrent jobs.
# HORIZON_LOCAL_MAX_PROCESSES=8
# HORIZON_LOCAL_WORKER_MEMORY=128

# Platform admin: /admin menu, Laravel Pulse, and Horizon/Pulse gates (non-local). Comma-separated emails.
# Local and automated tests treat every signed-in user as a platform admin.
# PLATFORM_ADMIN_EMAILS=you@company.com,ops@company.com

# Laravel Pulse (app performance dashboard at /pulse). Requires migrations; optional `php artisan pulse:work` for ingest.
# PULSE_ENABLED=true

# When true, server Manage (config previews / service actions) runs SSH via a queue worker so the
# Livewire request returns immediately. Requires `php artisan queue:work` unless QUEUE_CONNECTION=sync.
# SERVER_MANAGE_QUEUE_REMOTE_TASKS=true
# Optional queue name for those jobs (default queue if unset).
# SERVER_MANAGE_REMOTE_TASK_QUEUE=
# Optional Redis queue for cron “Run now” jobs (default queue if unset). Must be listed in Horizon workers.
# SERVER_CRON_RUN_QUEUE=
# Days to keep cron run history rows (pruned daily by `dply:prune-cron-job-runs`).
# DPLY_CRON_RUN_RETENTION_DAYS=90

# SSH probe cache for server Databases: MySQL/MariaDB (root) and PostgreSQL (postgres user) availability.
# SERVER_DATABASE_CAPABILITIES_TTL=120
# Max SQL import file size (bytes). Orgs can set a lower cap in organizations.database_workspace_settings.import_max_bytes.
# SERVER_DATABASE_IMPORT_MAX_BYTES=10485760
# Optional dedicated queue for SQL export jobs (list in Horizon workers when set).
# SERVER_DATABASE_EXPORT_QUEUE=
# Default for new orgs: allow public DB credential share links (override per org in database_workspace_settings JSON).
# SERVER_DATABASE_ORG_SHARES_DEFAULT=true

# Forward server metric snapshots to the ingest API after each collect (PushServerMetricSnapshotToIngestJob).
# Requires QUEUE_CONNECTION=redis (or database) and Horizon/queue:work. REDIS_QUEUE_RETRY_AFTER must exceed
# the longest job runtime. Set URL to https://your-by-host/api/metrics to store in server_metric_ingest_events.
# DPLY_METRICS_INGEST_ENABLED=true
# DPLY_METRICS_INGEST_URL="${APP_URL}/api/metrics"
# DPLY_METRICS_INGEST_TOKEN=   # same secret on sender and receiver; required for POST /api/metrics
# DPLY_METRICS_INGEST_TIMEOUT=15
# SERVER_METRICS_INGEST_QUEUE=
# Optional queue for background SSH “metrics readiness” probe (Metrics page). Horizon lists this when set.
# SERVER_METRICS_PROBE_QUEUE=
# Max points on the Metrics line charts (stored samples are pruned separately; default 96).
# DPLY_METRICS_CHART_POINTS=96
#
# Metrics workspace: hidden Livewire poll intervals (seconds).
# DPLY_METRICS_UI_POLL_PROBE_SECONDS=3
# DPLY_METRICS_UI_POLL_REMOTE_TASK_SECONDS=2
# DPLY_METRICS_UI_AUTO_REFRESH_SECONDS=60
#
# When the bundled server-metrics-snapshot.py changes, auto-deploy to ~/.dply/bin/ after collect (queued job).
# DPLY_METRICS_GUEST_SCRIPT_AUTO_UPGRADE=true
# SERVER_METRICS_GUEST_SCRIPT_UPGRADE_QUEUE=
#
# Guest → app push: after “Install monitoring” or first successful collect, a token + ~/.dply/metrics-callback.env
# and a marked user crontab block are deployed (queue worker). POSTs to /api/metrics/guest-push.
# APP_URL must be reachable from the server. Optional dedicated queue for env deploy.
# DPLY_METRICS_GUEST_PUSH_ENABLED=true
# SERVER_METRICS_GUEST_PUSH_DEPLOY_QUEUE=
# Five-field cron for the deploy user’s crontab (default every 5 minutes). Changing this re-queues guest-push sync on next collect.
# DPLY_METRICS_GUEST_PUSH_CRON=*/5 * * * *

# Local only: force stack provisioning to reinstall packages instead of using
# the built-in "already installed; skipping ..." guards.
# DPLY_SERVER_PROVISION_FORCE_REINSTALL=false

# Server Insights: optional synthetic “heartbeat” finding (info) to verify jobs + Overview; off by default.
# INSIGHTS_HEARTBEAT_DEFAULT_ENABLED=false
# Queue server + site insight runs after a successful site deploy (correlation + fresh checks).
# INSIGHTS_QUEUE_AFTER_DEPLOY=true
# Digest email: daily (default) or weekly (Monday flush).
# INSIGHTS_DIGEST_FREQUENCY=daily

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OAuth / Git providers (optional; leave empty to hide "Continue with GitHub" etc.)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# BITBUCKET_CLIENT_ID=
# BITBUCKET_CLIENT_SECRET=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# DigitalOcean OAuth for Server providers (optional; separate from Git OAuth). Callback: {APP_URL}/credentials/oauth/digitalocean/callback
# DIGITALOCEAN_OAUTH_CLIENT_ID=
# DIGITALOCEAN_OAUTH_CLIENT_SECRET=
# DIGITALOCEAN_OAUTH_REDIRECT_URI=

# Optional personal access token: load DigitalOcean regions & droplet prices on the create-server wizard
# when no org credential is selected (provisioning still uses the selected Server providers credential).
# DIGITALOCEAN_TOKEN=

# Optional: php artisan dply:demo-do-server (provisions as DPLY_DEMO_USER_EMAIL into their first org; removes prior dply-demo-* there). Uses DIGITALOCEAN_TOKEN if unset.
# DPLY_DEMO_DO_TOKEN=
# DPLY_DEMO_DO_REGION=nyc1
# DPLY_DEMO_DO_SIZE=s-1vcpu-1gb
# DPLY_DEMO_USER_EMAIL=tom.shafer@gmail.com
# DPLY_DEMO_ORG_SLUG=dply-automated-demo

# After cloud assigns a public IP, wait for TCP :22 before stack setup (avoids “Connection refused”).
# DPLY_SSH_READY_MAX_ATTEMPTS=45
# DPLY_SSH_READY_RETRY_SECONDS=8
# Linux user created during stack setup (same SSH key as root); app uses this for TaskRunner after setup.
# DPLY_SERVER_DEPLOY_SSH_USER=dply

# Install Supervisor during initial stack setup (default true). Set false to skip apt install on provision
# (use Server → Daemons → Install Supervisor if you add programs later).
# DPLY_INSTALL_SUPERVISOR_ON_PROVISION=true

# Server / credential provider feature flags (true/false). Roll out clouds gradually; DigitalOcean + Custom default on.
# DPLY_SERVER_PROVIDER_DIGITALOCEAN=true
# DPLY_SERVER_PROVIDER_CUSTOM=true
# DPLY_SERVER_PROVIDER_HETZNER=false
# DPLY_SERVER_PROVIDER_LINODE=false
# DPLY_SERVER_PROVIDER_VULTR=false
# DPLY_SERVER_PROVIDER_AKAMAI=false
# DPLY_SERVER_PROVIDER_SCALEWAY=false
# DPLY_SERVER_PROVIDER_UPCLOUD=false
# DPLY_SERVER_PROVIDER_EQUINIX_METAL=false
# DPLY_SERVER_PROVIDER_OVH=false
# DPLY_SERVER_PROVIDER_RACKSPACE=false
# DPLY_SERVER_PROVIDER_FLY_IO=false
# DPLY_SERVER_PROVIDER_RENDER=false
# DPLY_SERVER_PROVIDER_RAILWAY=false
# DPLY_SERVER_PROVIDER_COOLIFY=false
# DPLY_SERVER_PROVIDER_CAP_ROVER=false
# DPLY_SERVER_PROVIDER_AWS=false
# DPLY_SERVER_PROVIDER_GCP=false
# DPLY_SERVER_PROVIDER_AZURE=false
# DPLY_SERVER_PROVIDER_ORACLE=false

# Subscription limits (free tier when not on Pro Stripe price). Pro = unlimited servers & sites.
# SUBSCRIPTION_SERVERS_FREE_LIMIT=3
# SUBSCRIPTION_SITES_FREE_LIMIT=10

# Email verification for dashboard / gated actions (defaults off when APP_ENV=local). Uncomment to require it locally.
# DPLY_REQUIRE_EMAIL_VERIFICATION=true

# When true, only orgs on Pro can create tokens from Settings → API keys.
# DPLY_API_TOKENS_REQUIRE_PAID_PLAN=true

# Referrals: Stripe customer balance credit (cents) for referrer when a referred user’s org pays for Pro. 0 = track only.
# REFERRAL_BONUS_CREDIT_CENTS=1500

# Notification channel types shown in the UI (comma-separated). Add pushover, microsoft_teams, rocketchat, google_chat, mobile_app when supported end-to-end.
# DPLY_NOTIFICATION_CHANNEL_TYPES=slack,discord,email,telegram,webhook

# Server → Firewall add-rule form defaults (overrides config/server_firewall.php `new_rule`).
# SERVER_FIREWALL_DEFAULT_PORT=443
# SERVER_FIREWALL_DEFAULT_PROTOCOL=tcp
# SERVER_FIREWALL_DEFAULT_SOURCE=any
# SERVER_FIREWALL_DEFAULT_ACTION=allow
# SERVER_FIREWALL_DEFAULT_ENABLED=true

# Server → Services: background systemd inventory (see config/server_services.php).
# SERVER_SYSTEMD_INVENTORY_JOB_ENABLED=true
# SERVER_SYSTEMD_INVENTORY_SCHEDULE_ENABLED=true
# SERVER_SYSTEMD_SYNC_QUEUE=  # optional dedicated queue; add to Horizon when set
# SERVER_SERVICES_DEPLOYER_SYSTEMD_ACTIONS=false  # org can also set services_preferences.deployer_systemd_actions_enabled
# SERVER_SERVICES_SYSTEMD_NOTIFICATIONS_DIGEST=immediate  # immediate|hourly (hourly batches per channel; scheduler runs flush)
# SERVER_SERVICES_SYSTEMD_DIGEST_FLUSH_ENABLED=true

VITE_APP_NAME="${APP_NAME}"

# Optional: public URL of the Vite dev server when the app uses a tunnel (e.g. Expose) on APP_URL
# but HMR/assets must load from a second tunnel pointed at port 5173. Must be plain https URL only
# (no ANSI/terminal styling). If unset, npm run dev writes local host:port to public/hot.
# VITE_DEV_SERVER_URL=https://your-vite-share.tunnel.example.com

# Fleet operator API — GET /api/operator/summary (Bearer or X-Fleet-Operator-Token). Same secret as fleet-console polling.
# FLEET_OPERATOR_TOKEN=

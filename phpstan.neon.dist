includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 6

    parseModelCastsMethod: true
    databaseMigrationsPath:
        - database/migrations

    # The baseline is large; tolerate minor count drift between runs rather than
    # failing CI when an unrelated change shifts an inferred type.
    reportUnmatchedIgnoredErrors: false

    paths:
        - app/Actions
        - app/Console
        - app/Contracts
        - app/Enums
        - app/Events
        - app/Exceptions
        - app/Http
        - app/Jobs
        - app/Listeners
        - app/Mail
        - app/Mcp
        - app/Models
        - app/Notifications
        - app/Observers
        - app/Policies
        - app/Providers
        - app/Services
        - app/Support
        - app/TaskRunner
        - app/View
        - app/helpers.php
        - config
        - database
        - routes

    # Test files that live under app/ (PSR-4 namespace mismatches + a Pest guard
    # stub) — analysed via the test suite, not here.
    excludePaths:
        - app/*/Tests/*
        - app/**/Tests/*

        # FIXME: these three trigger PHPStan *internal* errors (which abort the
        # run rather than report cleanly), so they're excluded until fixed:
        #   - SecretsRestoreCommand: defines a `--version` option, which collides
        #     with Symfony's reserved global option (LogicException at runtime).
        #   - TaskRunCommand: same problem with a `--quiet` option.
        #   - DebounceDecorator: dispatches App\Jobs\ExecuteDebouncedAction,
        #     a class that does not exist anywhere in the codebase.
        - app/Console/Commands/SecretsRestoreCommand.php
        - app/TaskRunner/Commands/TaskRunCommand.php
        - app/Actions/Decorators/DebounceDecorator.php

        # Demo/example scripts that extend base classes which don't exist in the
        # codebase (EnhancedTask, Dply\Tasks\BaseTask) — non-runnable samples.
        - app/TaskRunner/Examples/*

    # Existing violations are captured in phpstan-baseline.neon so the suite is
    # green today; new code is held to the level above. Regenerate the baseline
    # with: composer analyse:baseline

<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- Bump the per-process memory limit from PHP's default 512M to 1G. The Feature
             suite renders the caches/databases/webserver workspaces (each ~3K-line blade
             templates with deep nested Livewire children) many times across the run in
             a single PHPUnit process; cumulative resident sets cross 512M near the end
             and the worker dies mid-render. Lifting the limit keeps `php artisan test`
             green without forcing per-test process isolation. -->
        <ini name="memory_limit" value="1G"/>
        <!-- Disable PHP's per-request max_execution_time during tests. Cumulative
             render time inside a single PHPUnit process (especially for tests that
             exercise the large workspace blades many times) drifts past PHP's
             default 90s slot, killing the worker. CLI defaults to 0 (unlimited)
             but Laravel's HandleExceptions reapplies a per-request limit; setting
             it to 0 explicitly removes the cap. Production keeps its own limits. -->
        <ini name="max_execution_time" value="0"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="dply_testing"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value=""/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>

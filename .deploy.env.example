# Copy to .deploy.env and fill in your server details.
# .deploy.env is gitignored.

DEPLOY_HOST=user@your-server-ip
# DEPLOY_WORKER_HOSTS="user@worker-1 user@worker-2"  # omit for single-server
# DEPLOY_APP_DIR=/var/www/dply
# DEPLOY_BRANCH=main
# DEPLOY_PHP=php
# DEPLOY_KEEP_RELEASES=5   # immutable releases retained per host (atomic deploys)

# Atomic-release deploys: see deploy/ATOMIC_RELEASES.md for the one-time bootstrap
# (seed shared/.env + shared/storage, repoint supervisor + nginx at current/).
